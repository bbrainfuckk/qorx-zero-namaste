# Choose openai for this edition or qwen for the Qwen edition.
QORX_ZERO_PROVIDER=openai

# Server-side only. Never prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Used by the Qwen edition.
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen3.7-plus
# US default: https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Singapore: https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
